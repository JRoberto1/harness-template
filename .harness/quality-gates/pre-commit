#!/bin/bash
# ============================================================
# Bifrost Quality Gate вЂ” Pre-commit Hook v1.4.0
# LГЄ .harness/config.json para protected_paths
# ============================================================
set -e

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; BOLD='\033[1m'; NC='\033[0m'
ERRORS=0; WARNINGS=0

fail() { echo -e "${RED}вќЊ ERRO: $1${NC}"; echo -e "   AГ‡ГѓO: $2"; [ -n "$3" ] && echo -e "   REF: $3"; ERRORS=$((ERRORS+1)); }
warn() { echo -e "${YELLOW}вљ пёЏ  AVISO: $1${NC}"; echo -e "   SUGESTГѓO: $2"; WARNINGS=$((WARNINGS+1)); }
pass() { echo -e "${GREEN}вњ“ $1${NC}"; }

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

echo -e "${BOLD}рџЊ‰ Bifrost Quality Gate v1.4.0${NC}"
echo "================================"

# 1. Protected paths (do .harness/config.json)
echo ""; echo "[ 1/7 ] Protected paths..."
if [ -f ".harness/config.json" ] && command -v node &>/dev/null; then
  PROTECTED=$(node -e "
    try {
      const c = require('./.harness/config.json');
      (c.protected_paths || []).forEach(p => console.log(p));
    } catch(e) {}
  " 2>/dev/null)

  PROTECTED_VIOLATED=""
  while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    # Remove trailing slash para comparaГ§ГЈo
    clean="${pattern%/}"
    MATCH=$(echo "$STAGED" | grep -E "^${clean}" || true)
    [ -n "$MATCH" ] && PROTECTED_VIOLATED+="$MATCH\n"
  done <<< "$PROTECTED"

  if [ -n "$PROTECTED_VIOLATED" ]; then
    fail "Arquivo protegido sendo commitado" \
         "Remova do staging: git reset HEAD <arquivo>" \
         ".harness/config.json#protected_paths"
  else
    pass "Protected paths respeitados"
  fi
else
  pass "config.json nГЈo encontrado вЂ” verificaГ§ГЈo pulada"
fi

# 2. Segredos
echo ""; echo "[ 2/7 ] Segredos..."
SECRET_FOUND=$(echo "$STAGED" | xargs -I{} git show ":{}" 2>/dev/null | \
  grep -iE "(password|api_key|secret|token)\s*[:=]\s*['\"][^'\"]{8,}|sk-[a-zA-Z0-9]{20,}|AKIA[0-9A-Z]{16}" | \
  grep -v "harness-ignore" || true)
[ -n "$SECRET_FOUND" ] && fail "PossГ­vel credencial no cГіdigo" "Mova para .env" "AGENTS.md" || pass "Sem segredos"

# 3. console.log
echo ""; echo "[ 3/7 ] console.log..."
JS=$(echo "$STAGED" | grep -E '\.(js|ts|jsx|tsx)$' || true)
CLOG=""
[ -n "$JS" ] && CLOG=$(echo "$JS" | xargs -I{} git show ":{}" 2>/dev/null | grep -n "console\.log" | grep -v "harness-ignore" || true)
[ -n "$CLOG" ] && warn "console.log detectado" "Use o logger do projeto ou '// harness-ignore'" || pass "Sem console.log"

# 4. TypeScript any
echo ""; echo "[ 4/7 ] TypeScript any..."
TS=$(echo "$STAGED" | grep -E '\.(ts|tsx)$' || true)
ANY=""
[ -n "$TS" ] && ANY=$(echo "$TS" | xargs -I{} git show ":{}" 2>/dev/null | grep -n ": any" | grep -v "harness-ignore" || true)
[ -n "$ANY" ] && fail "Uso de 'any' em TypeScript" "Defina o tipo explГ­cito" ".harness/domains/api.md" || pass "Sem 'any'"

# 5. Valores financeiros em float
echo ""; echo "[ 5/7 ] Valores financeiros..."
if [ -f ".harness/domains/juridico-financeiro.md" ]; then
  FLOAT=$(echo "$STAGED" | xargs -I{} git show ":{}" 2>/dev/null | \
    grep -iE "(preco|valor|amount|price|total)\s*[:=]\s*[0-9]+\.[0-9]+" | grep -v "harness-ignore" || true)
  [ -n "$FLOAT" ] && fail "Valor monetГЎrio em float" "Use centavos (integer). Ex: 1999 em vez de 19.99" ".harness/domains/juridico-financeiro.md" || pass "Sem float monetГЎrio"
else
  pass "DomГ­nio financeiro inativo вЂ” pulado"
fi

# 6. Directives atualizadas
echo ""; echo "[ 6/7 ] Directives..."
CODE=$(echo "$STAGED" | grep -E '\.(ts|js|py)$' || true)
DIRECTIVE=$(echo "$STAGED" | grep "^directives/" || true)
[ -n "$CODE" ] && [ -z "$DIRECTIVE" ] && \
  warn "CГіdigo modificado sem atualizar directive" "Verifique se directives/ precisa de atualizaГ§ГЈo" || pass "Directives verificadas"

# 7. .env
echo ""; echo "[ 7/7 ] Arquivos .env..."
ENV=$(echo "$STAGED" | grep -E "^\.env" | grep -v "\.example$" || true)
[ -n "$ENV" ] && fail ".env sendo commitado" "Adicione ao .gitignore. Use .env.example para documentar" || pass "Sem .env"

# Sincronizar espelhos automaticamente
if echo "$STAGED" | grep -q "^AGENTS.md$"; then
  echo ""
  echo -e "${YELLOW}в†’${NC} AGENTS.md modificado вЂ” sincronizando espelhos..."
  cp AGENTS.md CLAUDE.md 2>/dev/null && echo -e "  ${GREEN}вњ“${NC} CLAUDE.md"
  cp AGENTS.md GEMINI.md 2>/dev/null && echo -e "  ${GREEN}вњ“${NC} GEMINI.md"
  git add CLAUDE.md GEMINI.md 2>/dev/null || true
fi

# Resultado
echo ""; echo "================================"
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}вќЊ REPROVADO ($ERRORS erros, $WARNINGS avisos)${NC}"
  echo "   Adicione '// harness-ignore' para exceГ§Гµes justificadas."
  exit 1
elif [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}вљ пёЏ  APROVADO COM AVISOS ($WARNINGS)${NC}"
else
  echo -e "${GREEN}вњ… APROVADO${NC}"
fi
