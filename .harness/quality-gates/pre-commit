#!/bin/bash
# ============================================================
# Harness Quality Gate — Pre-commit Hook
# Instalação: cp .harness/quality-gates/pre-commit .git/hooks/pre-commit
#             chmod +x .git/hooks/pre-commit
# ============================================================
set -e

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'; BOLD='\033[1m'
ERRORS=0; WARNINGS=0

fail() { echo -e "${RED}❌ ERRO: $1${NC}"; echo -e "   AÇÃO: $2"; [ -n "$3" ] && echo -e "   REF: $3"; ERRORS=$((ERRORS+1)); }
warn() { echo -e "${YELLOW}⚠️  AVISO: $1${NC}"; echo -e "   SUGESTÃO: $2"; WARNINGS=$((WARNINGS+1)); }
pass() { echo -e "${GREEN}✓ $1${NC}"; }

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

echo -e "${BOLD}🔒 Harness Quality Gate${NC}"
echo "================================"

# 1. Segredos
echo ""; echo "[ 1/6 ] Segredos..."
SECRET_FOUND=$(echo "$STAGED" | xargs -I{} git show ":{}" 2>/dev/null | \
  grep -iE "(password|api_key|secret|token)\s*[:=]\s*['\"][^'\"]{8,}|sk-[a-zA-Z0-9]{20,}|AKIA[0-9A-Z]{16}" | \
  grep -v "harness-ignore" || true)
[ -n "$SECRET_FOUND" ] && fail "Possível credencial no código" "Mova para .env" "AGENTS.md#regras-absolutas" || pass "Sem segredos"

# 2. console.log
echo ""; echo "[ 2/6 ] console.log..."
JS=$(echo "$STAGED" | grep -E '\.(js|ts|jsx|tsx)$' || true)
CLOG_FOUND=""
[ -n "$JS" ] && CLOG_FOUND=$(echo "$JS" | xargs -I{} git show ":{}" 2>/dev/null | grep -n "console\.log" | grep -v "harness-ignore" || true)
[ -n "$CLOG_FOUND" ] && warn "console.log encontrado" "Use o logger do projeto ou adicione '// harness-ignore'" || pass "Sem console.log"

# 3. TypeScript any
echo ""; echo "[ 3/6 ] TypeScript any..."
TS=$(echo "$STAGED" | grep -E '\.(ts|tsx)$' || true)
ANY_FOUND=""
[ -n "$TS" ] && ANY_FOUND=$(echo "$TS" | xargs -I{} git show ":{}" 2>/dev/null | grep -n ": any" | grep -v "harness-ignore" || true)
[ -n "$ANY_FOUND" ] && fail "Uso de 'any' em TypeScript" "Defina o tipo explícito" ".harness/domains/api.md" || pass "Sem 'any'"

# 4. Valores financeiros em float
echo ""; echo "[ 4/6 ] Valores financeiros..."
if [ -f ".harness/domains/juridico-financeiro.md" ]; then
  FLOAT=$(echo "$STAGED" | xargs -I{} git show ":{}" 2>/dev/null | \
    grep -iE "(preco|valor|amount|price|total)\s*[:=]\s*[0-9]+\.[0-9]+" | grep -v "harness-ignore" || true)
  [ -n "$FLOAT" ] && fail "Valor monetário em float" "Use centavos (integer). Ex: 1999 em vez de 19.99" ".harness/domains/juridico-financeiro.md" || pass "Sem float monetário"
else
  pass "Domínio financeiro inativo — pulado"
fi

# 5. Directives atualizadas
echo ""; echo "[ 5/6 ] Directives..."
CODE=$(echo "$STAGED" | grep -E '\.(ts|js|py)$' || true)
DIRECTIVE=$(echo "$STAGED" | grep "^directives/" || true)
[ -n "$CODE" ] && [ -z "$DIRECTIVE" ] && \
  warn "Código modificado sem atualizar directive" "Verifique se directives/ precisa de atualização com os aprendizados" || pass "Directives verificadas"

# 6. .env
echo ""; echo "[ 6/6 ] Arquivos .env..."
ENV=$(echo "$STAGED" | grep -E "^\.env" | grep -v "\.example$" || true)
[ -n "$ENV" ] && fail "Arquivo .env sendo commitado: $ENV" "Adicione ao .gitignore. Use .env.example para documentar" || pass "Sem .env"

# Resultado
echo ""; echo "================================"
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}❌ REPROVADO ($ERRORS erros, $WARNINGS avisos)${NC}"
  echo "   Adicione '// harness-ignore' para exceções justificadas."
  exit 1
elif [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}⚠️  APROVADO COM AVISOS ($WARNINGS)${NC}"
else
  echo -e "${GREEN}✅ APROVADO${NC}"
fi
