#!/bin/bash
# Bifrost Quality Gate — Pre-commit Hook v2.0.0
set -e

RED='\033[0;31m'; YEL='\033[1;33m'; GRN='\033[0;32m'; BOLD='\033[1m'; NC='\033[0m'
ERRORS=0; WARNS=0

fail() { echo -e "${RED}❌ $1${NC}"; echo -e "   → $2"; ERRORS=$((ERRORS+1)); }
warn() { echo -e "${YEL}⚠  $1${NC}"; echo -e "   → $2"; WARNS=$((WARNS+1)); }
ok()   { echo -e "${GRN}✓${NC} $1"; }

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

echo -e "\n${BOLD}🌉 Bifrost Quality Gate v2.0.0${NC}"
echo "================================"

# 1. Protected paths
echo ""; echo "[ 1/7 ] Protected paths..."
if [ -f ".harness/config.json" ] && command -v node &>/dev/null; then
  PROTECTED=$(node -e "
    try{const c=require('./.harness/config.json');
    (c.protected_paths||[]).forEach(p=>console.log(p));}catch(e){}
  " 2>/dev/null)
  VIOLATED=""
  while IFS= read -r pat; do
    [ -z "$pat" ] && continue
    M=$(echo "$STAGED" | grep -E "^${pat%/}" || true)
    [ -n "$M" ] && VIOLATED+="$M\n"
  done <<< "$PROTECTED"
  [ -n "$VIOLATED" ] && fail "Arquivo protegido sendo commitado" "git reset HEAD <arquivo>" || ok "Protected paths respeitados"
else
  ok "config.json não encontrado — pulado"
fi

# 2. Segredos
echo ""; echo "[ 2/7 ] Segredos..."
FOUND=$(echo "$STAGED" | xargs -I{} git show ":{}" 2>/dev/null | \
  grep -iE "(password|api_key|secret|token)\s*[:=]\s*['\"][^'\"]{8,}|sk-[a-zA-Z0-9]{20,}" | \
  grep -v "harness-ignore" || true)
[ -n "$FOUND" ] && fail "Credencial detectada no código" "Mova para .env" || ok "Sem segredos"

# 3. console.log
echo ""; echo "[ 3/7 ] console.log..."
JS=$(echo "$STAGED" | grep -E '\.(js|ts|jsx|tsx)$' || true)
CLOG=""
[ -n "$JS" ] && CLOG=$(echo "$JS" | xargs -I{} git show ":{}" 2>/dev/null | grep -n "console\.log" | grep -v "harness-ignore" || true)
[ -n "$CLOG" ] && warn "console.log detectado" "Use o logger do projeto ou '// harness-ignore'" || ok "Sem console.log"

# 4. TypeScript any
echo ""; echo "[ 4/7 ] TypeScript any..."
TS=$(echo "$STAGED" | grep -E '\.(ts|tsx)$' || true)
ANY=""
[ -n "$TS" ] && ANY=$(echo "$TS" | xargs -I{} git show ":{}" 2>/dev/null | grep -n ": any" | grep -v "harness-ignore" || true)
[ -n "$ANY" ] && fail "Uso de 'any' em TypeScript" "Defina o tipo explícito" || ok "Sem 'any'"

# 5. Float monetário
echo ""; echo "[ 5/7 ] Valores monetários..."
if [ -f ".harness/domains/juridico-financeiro.md" ]; then
  FLOAT=$(echo "$STAGED" | xargs -I{} git show ":{}" 2>/dev/null | \
    grep -iE "(preco|valor|amount|price|total)\s*[:=]\s*[0-9]+\.[0-9]+" | grep -v "harness-ignore" || true)
  [ -n "$FLOAT" ] && fail "Valor monetário em float" "Use centavos (integer). Ex: 1999 em vez de 19.99" || ok "Sem float monetário"
else
  ok "Domínio financeiro inativo — pulado"
fi

# 6. .env
echo ""; echo "[ 6/7 ] Arquivos .env..."
ENV=$(echo "$STAGED" | grep -E "^\.env" | grep -v "\.example$" || true)
[ -n "$ENV" ] && fail ".env sendo commitado" "Adicione ao .gitignore. Use .env.example para documentar" || ok "Sem .env"

# 7. Directives
echo ""; echo "[ 7/7 ] Directives..."
CODE=$(echo "$STAGED" | grep -E '\.(ts|js|py)$' || true)
DIRECTIVE=$(echo "$STAGED" | grep "^directives/" || true)
[ -n "$CODE" ] && [ -z "$DIRECTIVE" ] && \
  warn "Código modificado sem atualizar directive" "Verifique se directives/ precisa de atualização (Hashimoto)" || ok "Directives verificadas"

# Auto-sync espelhos se AGENTS.md mudou
if echo "$STAGED" | grep -q "^AGENTS.md$"; then
  echo ""
  echo -e "${YEL}→${NC} AGENTS.md modificado — sincronizando espelhos..."
  cp AGENTS.md CLAUDE.md 2>/dev/null && echo -e "  ${GRN}✓${NC} CLAUDE.md"
  cp AGENTS.md GEMINI.md 2>/dev/null && echo -e "  ${GRN}✓${NC} GEMINI.md"
  git add CLAUDE.md GEMINI.md 2>/dev/null || true
fi

# Resultado
echo ""; echo "================================"
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}❌ REPROVADO ($ERRORS erros, $WARNS avisos)${NC}"
  echo "   Adicione '// harness-ignore' para exceções justificadas."
  exit 1
elif [ $WARNS -gt 0 ]; then
  echo -e "${YEL}⚠  APROVADO COM AVISOS ($WARNS)${NC}"
else
  echo -e "${GRN}✅ APROVADO${NC}"
fi
echo ""
